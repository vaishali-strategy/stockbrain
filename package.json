{
  "name": "stockbrain",
  "version": "2.4.0",
  "description": "Local-first, RAG-powered stock research desktop app (NSE/BSE focus)",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:frontend": "vite",
    "dev:backend": "uvicorn backend.main:app --reload --port 8765",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build:frontend": "vite build",
    "app": "npm run build:frontend && electron .",
    "app:dev": "VITE_DEV_SERVER=http://localhost:5173 electron .",
    "electron": "electron .",
    "build:backend": "pyinstaller backend/main.py --onefile --name stockbrain-server",
    "build": "npm run build:frontend && npm run build:backend && electron-builder",
    "seed": "python scripts/seed_vault.py"
  },
  "build": {
    "appId": "com.stockbrain.app",
    "productName": "StockBrain",
    "files": ["electron/**/*", "frontend/dist/**/*"],
    "extraResources": ["dist-backend/stockbrain-server"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "electron": "^31.7.7",
    "vite": "^5.4.0"
  }
}
