# --- StockBrain configuration ---
# Copy this file to .env and fill in values. The app runs WITHOUT an API key:
# search, quotes, charts, financials and news all use free yfinance data.
# An Anthropic API key (pay-as-you-go, console.anthropic.com — separate from any
# Claude subscription) only upgrades the AI company overview and unlocks chat/signals.

ANTHROPIC_API_KEY=
VAULT_PATH=                                  # absolute path to your Obsidian vault (optional)
CHROMA_PATH=./backend/db/chroma
NEWS_API_KEY=                                # optional, for NewsAPI.org

EMBED_MODEL=BAAI/bge-small-en-v1.5           # local ONNX via fastembed — free, offline, no torch
SIGNALS_MODEL=claude-haiku-4-5-20251001      # high-volume signal cards (cheap)
CHAT_MODEL=claude-sonnet-4-6                 # RAG chat
OVERVIEW_MODEL=claude-sonnet-4-6             # company overviews
# AGENT_MODEL=claude-opus-4-8                # reserved for a future agentic research engine
